<local:BaseWindow
    x:Class="LenovoLegionToolkit.WPF.Windows.Utils.ScriptWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LenovoLegionToolkit.WPF.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:LenovoLegionToolkit.WPF.Resources"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{x:Static resources:Resource.ScriptConsole_Title}"
    Width="900"
    Height="720"
    MinWidth="640"
    MinHeight="460"
    Background="Transparent"
    ResizeMode="CanResizeWithGrip"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <wpfui:TitleBar
            x:Name="_titleBar"
            Grid.Row="0"
            CanMaximize="false"
            ShowMaximize="false"
            ShowMinimize="false"
            UseSnapLayout="false" />

        <Grid
            Grid.Row="0"
            Height="28"
            Margin="16,10,16,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    IsHitTestVisible="False"
                    Text="{x:Static resources:Resource.ScriptConsole_Title}" />
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Margin="16,8,16,0"
            Padding="10,8"
            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Text="&#x26A0;" />
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{x:Static resources:Resource.ScriptConsole_Warn_Message}"
                    TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="16,16,16,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Text="{x:Static resources:Resource.ScriptConsole_Code_Title}" />
        </Grid>

        <Border
            Grid.Row="3"
            Margin="16,0,16,0"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource SolidBackgroundFillColorSecondary}" />
            </Border.Background>
            <Grid>
                <avalonedit:TextEditor
                    x:Name="_codeInput"
                    MinHeight="200"
                    Padding="12,10"
                    Background="Transparent"
                    BorderThickness="0"
                    FontFamily="Consolas"
                    FontSize="13"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    LineNumbersForeground="{DynamicResource TextFillColorTertiaryBrush}"
                    ShowLineNumbers="True"
                    SyntaxHighlighting="C#" />
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="16,8,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="_statusBorder"
                Grid.Column="0"
                Padding="10,5"
                VerticalAlignment="Center"
                CornerRadius="4">
                <TextBlock
                    x:Name="_statusLabel"
                    FontFamily="Consolas"
                    FontSize="11"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{x:Static resources:Resource.Ready}" />
            </Border>

            <wpfui:Button
                x:Name="_resetButton"
                Grid.Column="1"
                Margin="0,0,8,0"
                Appearance="Secondary"
                Click="Reset_Click"
                Content="{x:Static resources:Resource.Reset}" />

            <wpfui:Button
                x:Name="_executeButton"
                Grid.Column="2"
                Appearance="Primary"
                Click="Execute_Click"
                Content="{x:Static resources:Resource.Run}" />
        </Grid>

        <TextBlock
            Grid.Row="5"
            Margin="16,12,16,6"
            FontSize="12"
            FontWeight="SemiBold"
            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
            Text="{x:Static resources:Resource.ScriptConsole_Output_Title}" />

        <Border
            Grid.Row="6"
            Margin="16,0,16,0"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource SolidBackgroundFillColorSecondary}" />
            </Border.Background>
            <TextBox
                x:Name="_outputBox"
                Padding="14,10"
                Background="Transparent"
                BorderThickness="0"
                FontFamily="Consolas"
                FontSize="12"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                TextWrapping="NoWrap"
                VerticalScrollBarVisibility="Auto" />
        </Border>

        <Border Grid.Row="7" Height="16" />
    </Grid>
</local:BaseWindow>
