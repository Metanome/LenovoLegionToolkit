<local:BaseWindow
    x:Class="LenovoLegionToolkit.WPF.Windows.Utils.ScriptWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LenovoLegionToolkit.WPF.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:LenovoLegionToolkit.WPF.Resources"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{x:Static resources:Resource.ScriptConsole_Title}"
    Width="800"
    Height="600"
    MinWidth="640"
    MinHeight="460"
    Background="Transparent"
    ResizeMode="CanResizeWithGrip"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="250" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <wpfui:TitleBar
            x:Name="_titleBar"
            Grid.Row="0"
            CanMaximize="false"
            ShowMaximize="false"
            ShowMinimize="false"
            UseSnapLayout="false" />

        <Grid
            Grid.Row="0"
            Height="24"
            Margin="12,8,12,8">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="12"
                IsHitTestVisible="False"
                Text="{x:Static resources:Resource.ScriptConsole_Title}" />
        </Grid>

        <Grid Grid.Row="1" Margin="16,0,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="200" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- LEFT: Header -->
            <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="{x:Static resources:Resource.ScriptConsole_Code_Title}" />
                    
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal">
                    <wpfui:Button
                        x:Name="_resetButton"
                        Margin="0,0,8,0"
                        Padding="8,4"
                        Appearance="Transparent"
                        Click="Reset_Click"
                        Icon="{x:Static wpfui:SymbolRegular.ArrowReset24}"
                        ToolTip="{x:Static resources:Resource.Reset}" />
                    <wpfui:Button
                        x:Name="_executeButton"
                        Padding="8,4"
                        Appearance="Primary"
                        Click="Execute_Click"
                        Icon="{x:Static wpfui:SymbolRegular.Play24}"
                        ToolTip="{x:Static resources:Resource.Run}" />
                </StackPanel>
            </Grid>

            <!-- LEFT: Editor -->
            <Border
                Grid.Row="1"
                Grid.Column="0"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource SolidBackgroundFillColorSecondary}" />
                </Border.Background>
                <avalonedit:TextEditor
                    x:Name="_codeInput"
                    WordWrap="True"
                    Padding="12,10"
                    Background="Transparent"
                    BorderThickness="0"
                    FontFamily="Consolas"
                    FontSize="13"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    LineNumbersForeground="{DynamicResource TextFillColorTertiaryBrush}"
                    ShowLineNumbers="True"
                    SyntaxHighlighting="C#" />
            </Border>

            <!-- SPLITTER -->
            <Border
                Grid.Row="1"
                Grid.Column="1"
                Width="1"
                Margin="0,16,0,16"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="{DynamicResource DividerStrokeColorDefaultBrush}">
                <Border.OpacityMask>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0.0" Color="Transparent" />
                        <GradientStop Offset="0.2" Color="Black" />
                        <GradientStop Offset="0.8" Color="Black" />
                        <GradientStop Offset="1.0" Color="Transparent" />
                    </LinearGradientBrush>
                </Border.OpacityMask>
            </Border>
            
            <GridSplitter
                Grid.Row="1"
                Grid.Column="1"
                Width="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="Transparent"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Columns" />

            <!-- RIGHT: Header -->
            <Grid Grid.Row="0" Grid.Column="2" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="{x:Static resources:Resource.ScriptConsole_Output_Title}" />
                    
                <wpfui:Button
                    x:Name="_clearButton"
                    Grid.Column="1"
                    Padding="8,4"
                    Appearance="Transparent"
                    Click="Clear_Click"
                    Icon="{x:Static wpfui:SymbolRegular.Broom24}"
                    ToolTip="{x:Static resources:Resource.Clear}" />
            </Grid>

            <!-- RIGHT: Output -->
            <Border
                Grid.Row="1"
                Grid.Column="2"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource SolidBackgroundFillColorSecondary}" />
                </Border.Background>
                <avalonedit:TextEditor
                    x:Name="_outputBox"
                    WordWrap="True"
                    Padding="14,10"
                    Background="Transparent"
                    BorderThickness="0"
                    FontFamily="Consolas"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    IsReadOnly="True" />
            </Border>
        </Grid>

        <Border
            x:Name="_statusBorder"
            Grid.Row="2"
            Padding="8,4,8,6"
            Visibility="Collapsed"
            Background="Transparent">
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <wpfui:SymbolIcon
                    x:Name="_statusIcon"
                    Margin="0,0,4,0"
                    Symbol="Info24"
                    Visibility="Collapsed" />
                <TextBlock
                    x:Name="_statusLabel"
                    Focusable="True" />
            </StackPanel>
        </Border>
    </Grid>
</local:BaseWindow>
