<local:BaseWindow
    x:Class="LenovoLegionToolkit.WPF.Windows.Utils.DeviceInformationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:LenovoLegionToolkit.WPF.Controls"
    xmlns:custom="clr-namespace:LenovoLegionToolkit.WPF.Controls.Custom"
    xmlns:local="clr-namespace:LenovoLegionToolkit.WPF.Windows"
    xmlns:resources="clr-namespace:LenovoLegionToolkit.WPF.Resources"
    xmlns:utils="clr-namespace:LenovoLegionToolkit.WPF.Utils"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{x:Static resources:Resource.DeviceInformationWindow_Title}"
    Width="950"
    Height="570"
    ExtendsContentIntoTitleBar="True"
    FlowDirection="{x:Static utils:LocalizationHelper.Direction}"
    Loaded="DeviceInformationWindow_Loaded"
    ResizeMode="CanMinimize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <wpfui:TitleBar
            Grid.Row="0"
            CanMaximize="false"
            ShowMaximize="false"
            ShowMinimize="false"
            UseSnapLayout="false" />

        <Grid
            Grid.Row="0"
            Height="24"
            Margin="12,8,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <wpfui:SymbolIcon
                    Margin="0,0,8,0"
                    FontSize="16"
                    Foreground="{DynamicResource PaletteLightBlueBrush}"
                    Symbol="Laptop24" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    IsHitTestVisible="False"
                    Text="{x:Static resources:Resource.DeviceInformationWindow_Title}" />
            </StackPanel>
        </Grid>

        <wpfui:DynamicScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="16,0,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Left Column  -->
                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <!--  Device Details  -->
                    <Border
                        Margin="0,0,0,10"
                        Padding="16"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultSolidBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <wpfui:SymbolIcon
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="{DynamicResource PaletteLightBlueBrush}"
                                    Symbol="Laptop24" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                    Text="{x:Static resources:Resource.Device}" />
                            </StackPanel>

                            <TextBlock
                                x:Name="_modelLargeLabel"
                                Margin="0,0,0,12"
                                FontSize="15"
                                FontWeight="Bold"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <wpfui:SymbolIcon
                                    Grid.Column="0"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Symbol="Window24" />
                                <TextBlock
                                    x:Name="_osVersionLabel"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <wpfui:SymbolIcon
                                    Grid.Column="0"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Symbol="Key24" />
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,4,0"
                                        FontSize="12"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Static resources:Resource.SerialNumber}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBlock
                                        x:Name="_serialNumberLabel"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Focusable="True"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <wpfui:Button
                                    x:Name="_toggleSerialNumberButton"
                                    Grid.Column="2"
                                    Margin="0,0,4,0"
                                    Padding="4"
                                    VerticalAlignment="Center"
                                    Appearance="Transparent"
                                    Click="ToggleSerialNumberButton_OnClick"
                                    Cursor="Hand"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Icon="Eye24" />
                                <wpfui:Button
                                    x:Name="_copySerialNumberButton"
                                    Grid.Column="3"
                                    Padding="4"
                                    VerticalAlignment="Center"
                                    Appearance="Transparent"
                                    Click="CopyButton_OnClick"
                                    Cursor="Hand"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Icon="Copy24"
                                    Tag="{Binding ElementName=_serialNumberLabel, Path=Text}" />
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <wpfui:SymbolIcon
                                    Grid.Column="0"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Symbol="Tag24" />
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,4,0"
                                        FontSize="12"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Static resources:Resource.Model}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBlock
                                        x:Name="_modelLabel"
                                        Focusable="True"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <wpfui:Button
                                    x:Name="_copyModelButton"
                                    Grid.Column="2"
                                    Padding="4"
                                    VerticalAlignment="Center"
                                    Appearance="Transparent"
                                    Click="CopyButton_OnClick"
                                    Cursor="Hand"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Icon="Copy24"
                                    Tag="{Binding ElementName=_modelLabel, Path=Text}" />
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <wpfui:SymbolIcon
                                    Grid.Column="0"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Symbol="NumberSymbol24" />
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,4,0"
                                        FontSize="12"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Static resources:Resource.MachineType}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBlock
                                        x:Name="_mtmLabel"
                                        Focusable="True"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <wpfui:Button
                                    x:Name="_copyMtmButton"
                                    Grid.Column="2"
                                    Padding="4"
                                    VerticalAlignment="Center"
                                    Appearance="Transparent"
                                    Click="CopyButton_OnClick"
                                    Cursor="Hand"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Icon="Copy24"
                                    Tag="{Binding ElementName=_mtmLabel, Path=Text}" />
                            </Grid>

                            <Grid
                                x:Name="_biosCard"
                                Background="Transparent"
                                MouseLeftButtonUp="BiosCard_OnMouseLeftButtonUp">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <wpfui:SymbolIcon
                                    Grid.Column="0"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Symbol="Code24" />
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,4,0"
                                        FontSize="12"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Static resources:Resource.BiosVersion}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBlock
                                        x:Name="_biosLabel"
                                        Focusable="True"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <wpfui:Button
                                    x:Name="_copyBiosButton"
                                    Grid.Column="2"
                                    Padding="4"
                                    VerticalAlignment="Center"
                                    Appearance="Transparent"
                                    Click="CopyButton_OnClick"
                                    Cursor="Hand"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Icon="Copy24"
                                    Tag="{Binding ElementName=_biosLabel, Path=Text}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!--  Warranty  -->
                    <Border
                        x:Name="_warrantyInfo"
                        Margin="0,0,0,10"
                        Padding="16"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultSolidBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <wpfui:SymbolIcon
                                        x:Name="_warrantyStatusIcon"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Foreground="{DynamicResource PaletteGreenBrush}"
                                        Symbol="CheckmarkCircle24" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                        Text="{x:Static resources:Resource.Warranty}" />
                                </StackPanel>
                                <wpfui:Button
                                    x:Name="_refreshWarrantyButton"
                                    Grid.Column="1"
                                    Padding="4"
                                    Appearance="Transparent"
                                    Click="RefreshWarrantyButton_OnClick"
                                    Cursor="Hand"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Icon="ArrowClockwise24"
                                    ToolTip="{x:Static resources:Resource.Refresh}" />
                            </Grid>

                            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                <TextBlock
                                    x:Name="_warrantyStatusLabel"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource PaletteGreenBrush}" />
                            </StackPanel>

                            <Border
                                Height="6"
                                Margin="0,8,0,12"
                                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                ClipToBounds="True"
                                CornerRadius="3">
                                <ProgressBar
                                    x:Name="_warrantyProgressBar"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Value="100">
                                    <ProgressBar.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="{StaticResource PaletteGreenColor}" />
                                            <GradientStop Offset="1" Color="{StaticResource PaletteTealColor}" />
                                        </LinearGradientBrush>
                                    </ProgressBar.Foreground>
                                </ProgressBar>
                            </Border>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,4,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Static resources:Resource.StartDate}" /><Run Text=":" />
                                </TextBlock>
                                <TextBlock
                                    x:Name="_warrantyStartLabel"
                                    Grid.Column="1"
                                    FontSize="12"
                                    FontWeight="Medium"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,4,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Static resources:Resource.EndDate}" /><Run Text=":" />
                                </TextBlock>
                                <TextBlock
                                    x:Name="_warrantyEndLabel"
                                    Grid.Column="1"
                                    FontSize="12"
                                    FontWeight="Medium"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,4,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Static resources:Resource.DaysRemaining}" /><Run Text=":" />
                                </TextBlock>
                                <TextBlock
                                    x:Name="_warrantyDaysRemainingLabel"
                                    Grid.Column="1"
                                    FontSize="12"
                                    FontWeight="Medium"
                                    Foreground="{DynamicResource PaletteGreenBrush}" />
                            </Grid>

                            <wpfui:Button
                                x:Name="_warrantyLinkCardAction"
                                Margin="0,10,0,0"
                                Padding="0"
                                HorizontalAlignment="Left"
                                Appearance="Transparent"
                                BorderThickness="0"
                                Click="WarrantyLinkCardAction_OnClick"
                                Content="{x:Static resources:Resource.DeviceInformationWindow_LenovoSupport}"
                                Cursor="Hand"
                                Foreground="{DynamicResource PaletteLightBlueBrush}"
                                Icon="Open24"
                                IsEnabled="False" />
                        </StackPanel>
                    </Border>

                    <!--  Platform & Capabilities  -->
                    <Border
                        Margin="0,0,0,10"
                        Padding="16"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultSolidBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <wpfui:SymbolIcon
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="{DynamicResource PaletteLightBlueBrush}"
                                    Symbol="Info24" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                    Text="{x:Static resources:Resource.PlatformAndCapabilities}" />
                            </StackPanel>

                            <Grid x:Name="_seriesRow" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <wpfui:SymbolIcon
                                    Grid.Column="0"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Symbol="Layer24" />
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,4,0"
                                        FontSize="12"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Static resources:Resource.Series}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBlock
                                        x:Name="_seriesLabel"
                                        Focusable="True"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Grid>

                            <Grid x:Name="_generationRow" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <wpfui:SymbolIcon
                                    Grid.Column="0"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Symbol="History24" />
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,4,0"
                                        FontSize="12"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Static resources:Resource.Generation}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBlock
                                        x:Name="_generationLabel"
                                        Focusable="True"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Grid>



                            <Grid x:Name="_modesRow" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <wpfui:SymbolIcon
                                    Grid.Column="0"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Top"
                                    FontSize="16"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Symbol="Gauge24" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontSize="12"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run x:Name="_powerModesTitle" Text="{x:Static resources:Resource.PowerModes}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBlock
                                        x:Name="_powerModesLabel"
                                        Focusable="True"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Grid x:Name="_capabilitiesRow">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <wpfui:SymbolIcon
                                    Grid.Column="0"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Top"
                                    FontSize="16"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Symbol="DeveloperBoard24" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontSize="12"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Static resources:Resource.HardwareFeatures}" /><Run Text=":" />
                                    </TextBlock>
                                    <TextBlock
                                        x:Name="_capabilitiesLabel"
                                        MaxHeight="35"
                                        Focusable="True"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap" />
                                    <ToggleButton
                                        x:Name="_expandCapabilitiesButton"
                                        Padding="0,4"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="ExpandCapabilities_OnClick"
                                        Content="{x:Static resources:Resource.ShowMore}"
                                        Cursor="Hand"
                                        FontSize="12"
                                        Foreground="{DynamicResource PaletteLightBlueBrush}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!--  Middle Column  -->
                <StackPanel Grid.Column="1" Margin="5,0,5,0">

                    <!--  CPU  -->
                    <Border
                        Margin="0,0,0,10"
                        Padding="16"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultSolidBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <wpfui:SymbolIcon
                                    x:Name="_cpuIcon"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="{DynamicResource PaletteLightBlueBrush}"
                                    Symbol="DeveloperBoard24" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                    Text="{x:Static resources:Resource.CPU}" />
                            </StackPanel>
                            <TextBlock
                                x:Name="_cpuNameLabel"
                                Focusable="True"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                x:Name="_cpuDetailsLabel"
                                Margin="0,4,0,0"
                                Focusable="True"
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <!--  GPU  -->
                    <Border
                        Margin="0,0,0,10"
                        Padding="16"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultSolidBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <wpfui:SymbolIcon
                                    x:Name="_gpuIcon"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="{DynamicResource PaletteLightBlueBrush}"
                                    Symbol="Games24" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                    Text="{x:Static resources:Resource.GPU}" />
                            </StackPanel>
                            <ItemsControl x:Name="_gpuList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="{Binding Name, TargetNullValue={x:Static resources:Resource.Unknown}}"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                <Run Text="{Binding DisplayVram, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!--  RAM  -->
                    <Border
                        Margin="0,0,0,10"
                        Padding="16"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultSolidBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <wpfui:SymbolIcon
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="{DynamicResource PalettePurpleBrush}"
                                    Symbol="Database24" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                    Text="{x:Static resources:Resource.RAM}" />
                            </StackPanel>
                            <ItemsControl x:Name="_ramList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock
                                                    FontSize="14"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                                    <Run Text="{Binding CapacityGb, StringFormat=\{0:F0\}}" />
                                                    <Run Text="{x:Static resources:Resource.GB}" />
                                                    <Run Text=" " />
                                                    <Run Text="{Binding Generation, TargetNullValue={x:Static resources:Resource.Unknown}}" />
                                                </TextBlock>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                    <Run Text="{x:Static resources:Resource.Slot}" />
                                                    <Run Text="{Binding Slot}" />
                                                    <Run Text=" • " />
                                                    <Run Text="{Binding Manufacturer, TargetNullValue={x:Static resources:Resource.Unknown}}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                                <Run Text="{Binding SpeedMhz, TargetNullValue={x:Static resources:Resource.Unknown}}" />
                                                <Run Text="{x:Static resources:Resource.MHz}" />
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!--  Motherboard  -->
                    <Border
                        Margin="0,0,0,10"
                        Padding="16"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultSolidBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <wpfui:SymbolIcon
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="{DynamicResource PaletteGreenBrush}"
                                    Symbol="DeveloperBoard24" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                    Text="{x:Static resources:Resource.Motherboard}" />
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        x:Name="_motherboardNameLabel"
                                        Focusable="True"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <TextBlock
                                        x:Name="_motherboardDetailsLabel"
                                        Margin="0,4,0,0"
                                        Focusable="True"
                                        FontSize="12"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <wpfui:Button
                                    x:Name="_copyMotherboardButton"
                                    Grid.Column="1"
                                    Padding="4"
                                    VerticalAlignment="Center"
                                    Appearance="Transparent"
                                    Click="CopyButton_OnClick"
                                    Cursor="Hand"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Icon="Copy24"
                                    Tag="{Binding ElementName=_motherboardNameLabel, Path=Text}" />
                            </Grid>
                        </StackPanel>
                    </Border>


                </StackPanel>

                <!--  Right Column  -->
                <StackPanel Grid.Column="2" Margin="5,0,0,0">
                    <!--  Storage  -->
                    <Border
                        Margin="0,0,0,10"
                        Padding="16"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultSolidBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <wpfui:SymbolIcon
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="{DynamicResource PaletteLightBlueBrush}"
                                    Symbol="HardDrive20" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                    Text="{x:Static resources:Resource.Storage}" />
                            </StackPanel>
                            <ItemsControl x:Name="_diskList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,6">
                                            <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                <TextBlock
                                                    FontSize="14"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="{Binding Name, TargetNullValue={x:Static resources:Resource.Unknown}}" />
                                                <TextBlock
                                                    Margin="6,0,0,0"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding Label}" />
                                            </StackPanel>
                                            <Border
                                                Height="6"
                                                Margin="0,0,0,4"
                                                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                ClipToBounds="True"
                                                CornerRadius="3">
                                                <ProgressBar
                                                    x:Name="StorageProgressBar"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Maximum="{Binding SizeGb, Mode=OneWay}"
                                                    Value="{Binding UsedGb, Mode=OneWay}">
                                                    <ProgressBar.Foreground>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Offset="0" Color="{StaticResource PaletteLightBlueColor}" />
                                                            <GradientStop Offset="1" Color="{StaticResource PaletteTealColor}" />
                                                        </LinearGradientBrush>
                                                    </ProgressBar.Foreground>
                                                </ProgressBar>
                                            </Border>
                                            <TextBlock
                                                Margin="0"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                <Run Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontWeight="SemiBold" Text="{Binding UsedGb, StringFormat=\{0:F1\}, Mode=OneWay}" />
                                                <Run Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontWeight="SemiBold" Text="{x:Static resources:Resource.GB}" />
                                                <Run Text="{x:Static resources:Resource.Used}" />
                                                <Run Text="/" />
                                                <Run Text="{Binding SizeGb, StringFormat=\{0:F1\}, Mode=OneWay}" />
                                                <Run Text="{x:Static resources:Resource.GB}" />
                                            </TextBlock>
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                Text="{Binding DiskModel, TargetNullValue={x:Static resources:Resource.Unknown}}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!--  Displays  -->
                    <Border
                        Margin="0,0,0,10"
                        Padding="16"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultSolidBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <wpfui:SymbolIcon
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="{DynamicResource PaletteLightBlueBrush}"
                                    Symbol="Desktop24" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                    Text="{x:Static resources:Resource.Displays}" />
                            </StackPanel>
                            <ItemsControl x:Name="_displayList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="14"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    TextWrapping="Wrap">
                                                    <Run Text="{x:Static resources:Resource.DashboardPage_Display_Title}" /><Run Text=" " /><Run Text="{Binding Index, Mode=OneWay}" /><Run Text=": " /><Run Text="{Binding Model, TargetNullValue={x:Static resources:Resource.Unknown}, Mode=OneWay}" />
                                                </TextBlock>
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontSize="12"
                                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                    <Run Text="{Binding Width}" />
                                                    <Run Text="×" />
                                                    <Run Text="{Binding Height}" />
                                                    <Run Text=" @ " />
                                                    <Run Text="{Binding RefreshRate}" />
                                                    <Run Text=" " />
                                                    <Run Text="{x:Static resources:Resource.Hz}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!--  Battery  -->
                    <Border
                        x:Name="_batteryInfo"
                        Margin="0,0,0,10"
                        Padding="16"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultSolidBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <wpfui:SymbolIcon
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="{DynamicResource PaletteGreenBrush}"
                                    Symbol="BatteryCharge24" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                    Text="{x:Static resources:Resource.BatteryPage_Title}" />
                            </StackPanel>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,4,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Static resources:Resource.BatteryPage_LiveCharge_Title}" /><Run Text=":" />
                                </TextBlock>
                                <TextBlock
                                    x:Name="_batteryLiveChargeLabel"
                                    Grid.Column="1"
                                    FontSize="12"
                                    FontWeight="Medium"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Grid>

                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,4,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Static resources:Resource.BatteryPage_BatteryHealth_Title}" /><Run Text=":" />
                                </TextBlock>
                                <TextBlock
                                    x:Name="_batteryHealthLabel"
                                    Grid.Column="1"
                                    FontSize="12"
                                    FontWeight="Medium"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Grid>
                            <Border
                                Height="6"
                                Margin="0,0,0,10"
                                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                ClipToBounds="True"
                                CornerRadius="3">
                                <ProgressBar
                                    x:Name="_batteryHealthProgressBar"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Maximum="100" />
                            </Border>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,4,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Static resources:Resource.BatteryPage_DesignCapacity_Title}" /><Run Text=":" />
                                </TextBlock>
                                <TextBlock
                                    x:Name="_batteryDesignCapacityLabel"
                                    Grid.Column="1"
                                    FontSize="12"
                                    FontWeight="Medium"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,4,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Static resources:Resource.BatteryPage_FullChargeCapacity_Title}" /><Run Text=":" />
                                </TextBlock>
                                <TextBlock
                                    x:Name="_batteryFullCapacityLabel"
                                    Grid.Column="1"
                                    FontSize="12"
                                    FontWeight="Medium"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,4,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Static resources:Resource.BatteryPage_CycleCount_Title}" /><Run Text=":" />
                                </TextBlock>
                                <TextBlock
                                    x:Name="_batteryCycleCountLabel"
                                    Grid.Column="1"
                                    FontSize="12"
                                    FontWeight="Medium"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Grid>

                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,4,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Static resources:Resource.BatteryPage_ManufactureDate_Title}" /><Run Text=":" />
                                </TextBlock>
                                <TextBlock
                                    x:Name="_batteryManufactureDateLabel"
                                    Grid.Column="1"
                                    FontSize="12"
                                    FontWeight="Medium"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!--  Network  -->
                    <Border
                        Margin="0,0,0,10"
                        Padding="16"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultSolidBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <wpfui:SymbolIcon
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="{DynamicResource PaletteBlueBrush}"
                                    Symbol="Wifi124" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                    Text="{x:Static resources:Resource.NetworkAdapters}" />
                            </StackPanel>
                            <ItemsControl x:Name="_networkList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="{Binding Name, TargetNullValue={x:Static resources:Resource.Unknown}}"
                                                TextWrapping="Wrap" />
                                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                                <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                    <Run Text="{x:Static resources:Resource.MacAddress}" /><Run Text=":" />
                                                </TextBlock>
                                                <TextBlock
                                                    Margin="4,0,0,0"
                                                    FontSize="12"
                                                    FontWeight="Medium"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="{Binding MacAddress, TargetNullValue={x:Static resources:Resource.Unknown}}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </wpfui:DynamicScrollViewer>

        <wpfui:Snackbar
            x:Name="_snackBar"
            Grid.Row="1"
            HorizontalAlignment="Center"
            CloseButtonEnabled="False"
            Icon="Checkmark24"
            Timeout="1000" />
    </Grid>
</local:BaseWindow>
