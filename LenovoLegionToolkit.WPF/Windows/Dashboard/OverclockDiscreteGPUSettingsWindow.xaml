<local:BaseWindow
    x:Class="LenovoLegionToolkit.WPF.Windows.Dashboard.OverclockDiscreteGPUSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:LenovoLegionToolkit.WPF.Windows"
    xmlns:controls="clr-namespace:LenovoLegionToolkit.WPF.Controls"
    xmlns:custom="clr-namespace:LenovoLegionToolkit.WPF.Controls.Custom"
    xmlns:resources="clr-namespace:LenovoLegionToolkit.WPF.Resources"
    xmlns:utils="clr-namespace:LenovoLegionToolkit.WPF.Utils"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_Title}"
    Width="650"
    MinWidth="650"
    MaxWidth="800"
    SizeToContent="Height"
    FlowDirection="{x:Static utils:LocalizationHelper.Direction}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <wpfui:TitleBar
            Grid.Row="0"
            CanMaximize="false"
            ShowMaximize="false"
            ShowMinimize="false"
            UseSnapLayout="false" />

        <Grid
            Grid.Row="0"
            Height="24"
            Margin="12,8,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="12"
                IsHitTestVisible="False"
                Text="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_Title}" />
        </Grid>

        <Grid Grid.Row="1" Margin="16,16,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,4,0">
                    <!-- Overclocking Section -->
                    <TextBlock Text="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_Overclocking}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                    
                    <custom:CardControl Margin="0,0,0,8" Icon="Flash24">
                        <custom:CardControl.Header>
                            <controls:CardHeaderControl
                                Title="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_CoreFrequencyOffset_Title}"
                                Subtitle="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_CoreDesc}" />
                        </custom:CardControl.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Slider
                                x:Name="_coreSlider"
                                Width="180"
                                AutomationProperties.Name="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_CoreFrequencyOffset_Title}"
                                IsSnapToTickEnabled="True"
                                Minimum="0"
                                TickFrequency="1"
                                ValueChanged="CoreSlider_OnValueChanged" />
                            <Label
                                x:Name="_coreLabel"
                                Width="75"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontWeight="Medium" />
                        </StackPanel>
                    </custom:CardControl>

                    <custom:CardControl Margin="0,0,0,24" Icon="Memory16">
                        <custom:CardControl.Header>
                            <controls:CardHeaderControl
                                Title="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_MemoryFrequencyOffset_Title}"
                                Subtitle="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_MemoryDesc}" />
                        </custom:CardControl.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Slider
                                x:Name="_memorySlider"
                                Width="180"
                                AutomationProperties.Name="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_MemoryFrequencyOffset_Title}"
                                IsSnapToTickEnabled="True"
                                Minimum="0"
                                TickFrequency="1"
                                ValueChanged="MemorySlider_OnValueChanged" />
                            <Label
                                x:Name="_memoryLabel"
                                Width="75"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontWeight="Medium" />
                        </StackPanel>
                    </custom:CardControl>

                    <!-- Undervolting Section -->
                    <TextBlock Text="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_Undervolting}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />

                    <custom:CardControl Margin="0,0,0,8" Icon="ArrowDownload24">
                        <custom:CardControl.Header>
                            <controls:CardHeaderControl
                                Title="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_VoltageOffset}"
                                Subtitle="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_VoltageOffsetDesc}" />
                        </custom:CardControl.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Slider
                                x:Name="_voltageOffsetSlider"
                                Width="180"
                                AutomationProperties.Name="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_VoltageOffset}"
                                IsSnapToTickEnabled="True"
                                TickFrequency="5"
                                ValueChanged="VoltageOffsetSlider_OnValueChanged" />
                            <Label
                                x:Name="_voltageOffsetLabel"
                                Width="60"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontWeight="Medium" />
                        </StackPanel>
                    </custom:CardControl>

                    <custom:CardControl Margin="0,0,0,8" Icon="LockClosed24">
                        <custom:CardControl.Header>
                            <controls:CardHeaderControl
                                Title="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_VoltageLock}"
                                Subtitle="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_VoltageLockDesc}" />
                        </custom:CardControl.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Slider
                                x:Name="_voltageLockSlider"
                                Width="180"
                                AutomationProperties.Name="{x:Static resources:Resource.OverclockDiscreteGPUSettingsWindow_VoltageLock}"
                                IsSnapToTickEnabled="True"
                                TickFrequency="5"
                                ValueChanged="VoltageLockSlider_OnValueChanged" />
                            <Label
                                x:Name="_voltageLockLabel"
                                Width="60"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontWeight="Medium" />
                        </StackPanel>
                    </custom:CardControl>
                </StackPanel>
            </ScrollViewer>

            <Grid
                x:Name="_applyCloseGrid"
                Grid.Row="1"
                Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <wpfui:Button
                    Grid.Column="1"
                    MinWidth="100"
                    Click="ApplyButton_Click"
                    Content="{x:Static resources:Resource.Apply}" />

                <wpfui:Button
                    Grid.Column="2"
                    MinWidth="100"
                    Margin="8,0,0,0"
                    Appearance="Primary"
                    Click="ApplyAndCloseButton_Click"
                    Content="{x:Static resources:Resource.ApplyAndClose}" />
            </Grid>

            <Grid
                x:Name="_saveGrid"
                Grid.Row="1"
                Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <wpfui:Button
                    Grid.Column="1"
                    MinWidth="100"
                    Appearance="Primary"
                    Click="SaveButton_Click"
                    Content="{x:Static resources:Resource.Save}" />
            </Grid>
        </Grid>

    </Grid>
</local:BaseWindow>
